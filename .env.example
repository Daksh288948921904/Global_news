# Supabase (project settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-jwt-here

# Shared secret — set the same value in robin_cc's GLOBAL_NEWS_API_KEY
INGEST_API_KEY=changeme-generate-a-strong-random-string

# Groq API keys for LLM news verification (groq.com → API Keys)
GROQ_API_KEY=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...
GROQ_API_KEY_4=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
